# Denver Trades — example environment file
# Copy to .env.local for development, or set the same keys in Vercel project settings.
# `NEXT_PUBLIC_*` keys are exposed to the browser; everything else stays server-side.

# ─── Supabase (required) ───────────────────────────────────────────────
# Find these in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI providers (required) ────────────────────────────────────────────
# Anthropic Claude — primary reasoning / writing model.
CLAUDE_API_KEY=
# Google Gemini — fallback + multimodal (doc audit).
GEMINI_API_KEY=
# Currently installed but unused — drop the package or wire it for embeddings.
OPENAI_API_KEY=

# ─── Apify (Lead Scraper Agent) ────────────────────────────────────────
# Without APIFY_TOKEN the Lead Scraper falls back to simulation mode
# (clearly labeled in the UI banner + toast).
APIFY_TOKEN=
APIFY_ACTOR_ID=apify~google-maps-scraper
# Shared secret sent to /api/webhooks/apify in the x-denver-webhook-secret header.
APIFY_WEBHOOK_SECRET=

# ─── Twilio (WhatsApp inbound + outbound) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Number formatted as `whatsapp:+14155552671`.
TWILIO_WHATSAPP_NUMBER=
# Shared secret for the JSON test path on /api/webhooks/whatsapp.
WHATSAPP_WEBHOOK_SECRET=

# ─── Cron & app URLs ────────────────────────────────────────────────────
# Required in production. Vercel cron must send `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
# Public site URL — falls back behind VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
# Set to your custom domain once you add one (e.g. https://app.denver-trades.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Used as the OAuth redirect target in auth/callback if NEXT_PUBLIC_SITE_URL is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Legacy (to remove) ────────────────────────────────────────────────
# Used by the temporary DEFAULT_ORG_ID fallback in src/lib/auth/server.ts.
# Plan: remove once multi-tenant join/invite flow lands (Phase 4).
DENVER_TRADES_DEFAULT_ORG_ID=
